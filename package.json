{
  "name": "usedexchange",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup-ui": "bash scripts/setup-ui.sh",
    "upload-images": "tsx scripts/sync-images.ts --mode upload",
    "create-item": "tsx scripts/create-item.ts",
    "create-template": "tsx scripts/create-template.ts",
    "new": "tsx scripts/create-item.ts",
    "mark-sold": "tsx scripts/mark-sold.ts",
    "prebuild": "tsx scripts/sync-images.ts --mode build-check && tsx scripts/build-search-index.ts",
    "build": "next build",
    "postbuild": "tsx scripts/postbuild.ts",
    "dev": "tsx scripts/sync-images.ts --mode dev-sync && next dev --turbo",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@tabler/icons-react": "^3.44.0",
    "@vercel/analytics": "^1.3.0",
    "@vercel/speed-insights": "^1.0.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "fuse.js": "^7.0.0",
    "mini-svg-data-uri": "^1.4.4",
    "motion": "^12.40.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^2.3.0",
    "three": "^0.184.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "next-sitemap": "^4.2.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
